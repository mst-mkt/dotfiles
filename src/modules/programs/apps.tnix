{ delib, host, pkgs, ... }:
let
  _delib :: ProjectDelib; _delib = delib;
  _host :: Host; _host = host;
  _pkgs :: Pkgs; _pkgs = pkgs;
in
_delib.module {
  name = "programs.apps";
  options = _delib.singleEnableOption _host.guiFeatured;
  home = {
    ifEnabled = {
      home = {
        packages = [
          _pkgs.vivaldi
          _pkgs.mattermost-desktop
          _pkgs.slack
          _pkgs.discord
        ];
      };
    };
  };
}
