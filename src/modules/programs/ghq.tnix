{ delib, host, pkgs, ... }:
let
  _delib :: ProjectDelib; _delib = delib;
  _host :: Host; _host = host;
  _pkgs :: Pkgs; _pkgs = pkgs;
in
_delib.module {
  name = "programs.ghq";
  options = _delib.singleEnableOption _host.cliFeatured;
  home = {
    ifEnabled = {
      home = {
        packages = [ _pkgs.ghq ];
      };
      programs = {
        git = {
          settings = {
            ghq = {
              root = "~/_";
            };
          };
        };
      };
    };
  };
}
