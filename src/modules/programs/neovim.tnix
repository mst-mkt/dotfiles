{ delib, host, ... }:
let
  _delib :: ProjectDelib; _delib = delib;
  _host :: Host; _host = host;
in
_delib.module {
  name = "programs.neovim";
  options = _delib.singleEnableOption _host.cliFeatured;
  nixos = {
    ifEnabled = {
      programs = {
        command-not-found = {
          enable = false;
        };
        neovim = {
          enable = true;
          defaultEditor = true;
          viAlias = true;
          vimAlias = true;
        };
      };
    };
  };
}
