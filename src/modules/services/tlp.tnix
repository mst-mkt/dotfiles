{ delib, host, ... }:
let
  _delib :: ProjectDelib; _delib = delib;
  _host :: Host; _host = host;
in
_delib.module {
  name = "services.tlp";
  options = _delib.singleEnableOption _host.isLaptop;
  nixos = {
    ifEnabled = {
      services = {
        tlp = { enable = true; };
      };
    };
  };
}
